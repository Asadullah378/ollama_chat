# Copy to `.env` in this directory (same folder as `main.py`).
# `main.py` loads this file automatically via python-dotenv (no need for `uvicorn --env-file` unless you prefer it).

# --- PostgreSQL (documents + chat persistence) ---
# Required for /api/documents, /api/chats/*, and chat with saved_document_ids.
# Tables are created on API startup (stored_documents, chat_sessions, chat_messages, chat_preferences).
# Or run manually: cd backend && python -m db.migrate
# Use asyncpg (plain `postgresql://...` is rewritten to `postgresql+asyncpg://...` on startup).
# You must create this database in Postgres first, e.g.:
#   psql -U postgres -c 'CREATE DATABASE ollama_chat;'
#   -- or pick any name and set the path segment before ? or end of URL to match.
DATABASE_URL=postgresql+asyncpg://ollama:ollama@127.0.0.1:5432/ollama_chat

# Log SQL statements (1 / true / yes)
# SQL_ECHO=false

# --- Ollama ---
# Base URL for the Ollama HTTP API (used by the Python client and proxy routes).
OLLAMA_HOST=http://127.0.0.1:11434

# --- HTTP API (FastAPI) ---
# Comma-separated origins for browser CORS (Vite default below).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Document upload / storage (library router) ---
# Max upload size in megabytes
# DOC_UPLOAD_MAX_MB=80

# Max characters of MinerU Markdown to persist per document (truncated if larger)
# DOC_STORE_MAX_CHARS=2000000

# --- Chat: injected document context ---
# Max characters of combined Markdown sent to the model as the document system block
# DOC_CONTEXT_MAX_CHARS=200000

# When library documents are attached, disable Ollama think= for Qwen models (reduces
# reasoning leaking into the visible answer). Set false to keep Model reasoning on.
# DOC_CHAT_DISABLE_THINK_FOR_QWEN=true

# --- RAG (retrieval-augmented generation) ---
# Embedding model used to index documents on upload and to embed user queries.
#
# Qwen3-Embedding is a Matryoshka model: every variant (0.6B / 4B / 8B) accepts
# a `dimensions` parameter and returns a vector of that size, so EMBEDDING_DIM
# does NOT have to match the model's native max width. The backend sends the
# EMBEDDING_DIM value as the `dimensions` field to Ollama on every embed call.
#
# Native max output dimensions by variant (for reference):
#   qwen3-embedding:0.6b   → 1024 dim native  (~640 MB,  fast,  best default)
#   qwen3-embedding:4b     → 2560 dim native  (~2.5 GB)
#   qwen3-embedding:8b     → 4096 dim native  (~4.7 GB, :latest is usually this)
#
# Why 1024? pgvector's HNSW index has a hard limit of 2000 dimensions on the
# default `vector` type, so anything > 2000 dim cannot be indexed for ANN search
# and falls back to a sequential scan. 1024 is also the dimension the Qwen3
# model card recommends for fast retrieval. Stick with 1024 unless you have a
# very specific reason to change it.
#
# Whenever you change EMBEDDING_DIM, recreate the chunks table:
#     cd backend && python -m db.migrate --reset-chunks
# then restart the backend so it re-embeds all pending documents.
# EMBEDDING_MODEL=qwen3-embedding:latest
# EMBEDDING_DIM=1024
# EMBEDDING_BATCH_SIZE=16
# EMBEDDING_TIMEOUT_SEC=180

# Retrieval tuning
# RAG_TOP_K=12
# RAG_CONTEXT_MAX_CHARS=30000
# RAG_MIN_SIMILARITY=0.2

# --- MinerU (subprocess: python -m mineru) ---
# Backend: pipeline (CPU-friendly), hybrid, vlm, etc. See MinerU CLI docs.
# MINERU_BACKEND=pipeline

# Subprocess timeout in seconds
# MINERU_TIMEOUT_SEC=900

# Set to 1 / true to include MinerU output tree in stored extra_meta (debug)
# MINERU_DEBUG=

# MinerU reads many optional variables (models, devices, HF mirrors, etc.).
# See: https://github.com/opendatalab/mineru
